#!name=Sửa định vị Apple WLOC
#!desc=Sửa toạ độ trả về từ dịch vụ định vị mạng của Apple | Shortcuts (khuyên dùng): Đặt vị trí WLOC https://www.icloud.com/shortcuts/ea9629bfaf0744e1990d07494bc36d5a Khôi phục WLOC https://www.icloud.com/shortcuts/38f9c92948564e89b56f39c4f7ca52ea
#!icon=https://raw.githubusercontent.com/2KGT/build/refs/heads/main/wloc/wloc.jpg
#!author=Yu9191 Rewrite
#!homepage=https://github.com/2KGT/build/tree/main/wloc
#!openUrl=https://build-4sl.pages.dev/

[Argument]
longitude = input, "113.94114", tag=Kinh độ (toạ độ chọn online sẽ được ưu tiên)
latitude = input, "22.544577", tag=Vĩ độ (toạ độ chọn online sẽ được ưu tiên)
accuracy = input, "25", tag=Độ chính xác (mét)
logLevel = select, "info", "off", "error", "warn", "debug", "all", tag=Cấp độ log

[Script]
http-response ^https?:\/\/gs-loc(-cn)?\.apple\.com\/clls\/wloc script-path=https://raw.githubusercontent.com/2KGT/build/refs/heads/main/wloc/dist/wloc.js, requires-body=true, binary-body-mode=true, timeout=30, tag=Apple WLOC, argument=[{longitude},{latitude},{accuracy},{logLevel}]
http-request ^https?:\/\/gs-loc(-cn)?\.apple\.com\/wloc-settings\/save script-path=https://raw.githubusercontent.com/2KGT/build/refs/heads/main/wloc/dist/wloc-settings.js, timeout=10, tag=WLOC Settings

[MITM]
hostname = gs-loc.apple.com, gs-loc-cn.apple.com
